// ============================================================================
// KEYBINDING NAMESPACES (macOS)
// ============================================================================
// Cmd+G  = Go to    (definition, references, type, implementation, back, forward, problem)
// Cmd+T  = Terminal (toggle, create, kill, split, find, focus next/prev)
// Cmd+F  = Focus    (editor groups 1-3, file explorer, copilot, new file)
// Cmd+R  = Refactor (rename, ...)
// Cmd+A  = Action   (quick fix, format, organize imports, find-and-replace)
// Cmd+W  = Window   (split right, split down, move editor, close)
// Cmd+H  = Hover    (editor, debug, tree — context-dependent)
// Cmd+O  = Symbol navigation (file-level), Cmd+Shift+O = workspace symbols
//
// Vim still uses Ctrl internally — Ctrl overrides are for Vim only.
// Cmd+C / Cmd+V / Cmd+P are preserved for copy / paste / quick open.
// ============================================================================

[
    // =====================================================================
    // VIM OVERRIDES — reclaim Ctrl keys from Vim plugin
    // On Mac, Vim extension still intercepts Ctrl+*, not Cmd+*
    // Ctrl+V stays with Vim (visual block mode)
    // =====================================================================
    {
        "key": "ctrl+p",
        "command": "workbench.action.quickOpen"
    },
    {
        "key": "ctrl+a",
        "command": "-extension.vim_ctrl+a",
        "when": "editorTextFocus && vim.active && vim.use<C-a> && !inDebugRepl"
    },
    {
        "key": "ctrl+z",
        "command": "-extension.vim_ctrl+z",
        "when": "editorTextFocus && vim.active && vim.use<C-z> && !inDebugRepl"
    },
    {
        "key": "ctrl+y",
        "command": "-extension.vim_ctrl+y",
        "when": "editorTextFocus && vim.active && vim.use<C-y> && !inDebugRepl"
    },
    {
        "key": "ctrl+h",
        "command": "-extension.vim_ctrl+h",
        "when": "editorTextFocus && vim.active && vim.use<C-h> && !inDebugRepl"
    },
    {
        "key": "ctrl+o",
        "command": "-extension.vim_ctrl+o",
        "when": "editorTextFocus && vim.active && vim.use<C-o> && !inDebugRepl"
    },

    // =====================================================================
    // Cmd+G = GO TO
    // =====================================================================

    // Cmd+G D — Go to Definition
    {
        "key": "cmd+g cmd+d",
        "command": "editor.action.revealDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor"
    },
    {
        "key": "f12",
        "command": "-editor.action.revealDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor"
    },

    // Cmd+G R — Go to References
    {
        "key": "cmd+g cmd+r",
        "command": "editor.action.goToReferences",
        "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },
    {
        "key": "shift+f12",
        "command": "-editor.action.goToReferences",
        "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },

    // Cmd+G T — Go to Type Definition
    {
        "key": "cmd+g cmd+t",
        "command": "editor.action.goToTypeDefinition",
        "when": "editorTextFocus && isDefinedRegistrationProvider && !isInEmbeddedEditor"
    },

    // Cmd+G I — Go to Implementation
    {
        "key": "cmd+g cmd+i",
        "command": "editor.action.goToImplementation",
        "when": "editorHasImplementationProvider && editorTextFocus && !isInEmbeddedEditor"
    },
    {
        "key": "cmd+f12",
        "command": "-editor.action.goToImplementation",
        "when": "editorHasImplementationProvider && editorTextFocus && !isInEmbeddedEditor"
    },

    // Cmd+G B — Go Back (navigate backward)
    {
        "key": "cmd+g cmd+b",
        "command": "workbench.action.navigateBack"
    },

    // Cmd+G F — Go Forward (navigate forward)
    {
        "key": "cmd+g cmd+f",
        "command": "workbench.action.navigateForward"
    },

    // Cmd+G P — Go to next Problem/diagnostic
    {
        "key": "cmd+g cmd+p",
        "command": "editor.action.marker.next",
        "when": "editorFocus"
    },
    {
        "key": "alt+f8",
        "command": "-editor.action.marker.next",
        "when": "editorFocus"
    },

    // Cmd+G Shift+P — Go to previous Problem/diagnostic
    {
        "key": "cmd+g cmd+shift+p",
        "command": "editor.action.marker.prev",
        "when": "editorFocus"
    },
    {
        "key": "shift+alt+f8",
        "command": "-editor.action.marker.prev",
        "when": "editorFocus"
    },

    // =====================================================================
    // Cmd+H = HOVER (context-dependent)
    // Note: disables macOS "hide window" default — if you need that,
    //       remap it in System Preferences > Keyboard > Shortcuts
    // =====================================================================
    {
        "key": "cmd+h",
        "command": "editor.debug.action.showDebugHover",
        "when": "editorTextFocus && inDebugMode"
    },
    {
        "key": "cmd+k cmd+i",
        "command": "-editor.debug.action.showDebugHover",
        "when": "editorTextFocus && inDebugMode"
    },
    {
        "key": "cmd+h",
        "command": "editor.action.showHover",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+k cmd+i",
        "command": "-editor.action.showHover",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+h",
        "command": "workbench.action.showTreeHover",
        "when": "customTreeView && listFocus && !inputFocus"
    },
    {
        "key": "cmd+k cmd+i",
        "command": "-workbench.action.showTreeHover",
        "when": "customTreeView && listFocus && !inputFocus"
    },

    // =====================================================================
    // Cmd+A = ACTION (code actions, formatting, refactoring operations)
    // Note: disables macOS "select all" on Cmd+A first chord —
    //       select all still works via Vim's ggVG or you can add
    //       Cmd+Shift+A as select all if needed.
    // =====================================================================

    // Cmd+A Q — Quick Fix
    {
        "key": "cmd+a cmd+q",
        "command": "editor.action.quickFix",
        "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
    },
    {
        "key": "cmd+.",
        "command": "-editor.action.quickFix",
        "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
    },

    // Cmd+A F — Format Document
    {
        "key": "cmd+a cmd+f",
        "command": "editor.action.formatDocument",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
    },

    // Cmd+A S — Format Selection
    {
        "key": "cmd+a cmd+s",
        "command": "editor.action.formatSelection",
        "when": "editorHasDocumentSelectionFormattingProvider && editorTextFocus && !editorReadonly"
    },

    // Cmd+A O — Organize Imports
    {
        "key": "cmd+a cmd+o",
        "command": "editor.action.organizeImports",
        "when": "editorTextFocus && !editorReadonly && supportedCodeAction =~ /(\\s|^)source\\.organizeImports\\s*($|\\|)/"
    },

    // Cmd+A R — Find and Replace
    {
        "key": "cmd+a cmd+r",
        "command": "editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "cmd+alt+f",
        "command": "-editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },

    // Cmd+A E — Extract to function (refactor)
    {
        "key": "cmd+a cmd+e",
        "command": "editor.action.codeAction",
        "args": { "kind": "refactor.extract.function" },
        "when": "editorTextFocus && !editorReadonly"
    },

    // =====================================================================
    // Cmd+R = REFACTOR
    // =====================================================================

    // Cmd+R N — Rename Symbol
    {
        "key": "cmd+r cmd+n",
        "command": "editor.action.rename",
        "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
    },
    {
        "key": "f2",
        "command": "-editor.action.rename",
        "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
    },

    // =====================================================================
    // Cmd+W = WINDOW / SPLITS
    // Note: disables "close tab" on bare Cmd+W — the chord requires a
    //       second keypress, so accidental closes are prevented.
    //       Cmd+W C explicitly closes. Single Cmd+W waits for second key.
    // =====================================================================

    // Cmd+W S — Split Editor Right
    {
        "key": "cmd+w cmd+s",
        "command": "workbench.action.splitEditorRight"
    },

    // Cmd+W V — Split Editor Down
    {
        "key": "cmd+w cmd+v",
        "command": "workbench.action.splitEditorDown"
    },

    // Cmd+W M — Move Editor to Next Group
    {
        "key": "cmd+w cmd+m",
        "command": "workbench.action.moveEditorToNextGroup"
    },

    // Cmd+W C — Close Active Editor
    {
        "key": "cmd+w cmd+c",
        "command": "workbench.action.closeActiveEditor"
    },

    // =====================================================================
    // Cmd+F = FOCUS
    // Note: Cmd+F is no longer "find" — find is moved to Cmd+Alt+F.
    // =====================================================================

    // Cmd+F C — Focus Copilot Chat
    {
        "key": "cmd+f cmd+c",
        "command": "workbench.panel.chat.view.copilot.focus"
    },

    // Cmd+F 1/2/3 — Focus Editor Groups
    {
        "key": "cmd+f cmd+1",
        "command": "workbench.action.focusFirstEditorGroup"
    },
    {
        "key": "cmd+1",
        "command": "-workbench.action.focusFirstEditorGroup"
    },
    {
        "key": "cmd+f cmd+2",
        "command": "workbench.action.focusSecondEditorGroup"
    },
    {
        "key": "cmd+2",
        "command": "-workbench.action.focusSecondEditorGroup"
    },
    {
        "key": "cmd+f cmd+3",
        "command": "workbench.action.focusThirdEditorGroup"
    },
    {
        "key": "cmd+3",
        "command": "-workbench.action.focusThirdEditorGroup"
    },

    // Cmd+F F — Focus File Explorer
    {
        "key": "cmd+f cmd+f",
        "command": "workbench.explorer.fileView.focus"
    },

    // Cmd+F N — New File (in explorer)
    {
        "key": "cmd+f cmd+n",
        "command": "explorer.newFile",
        "when": "explorerViewletFocus"
    },

    // =====================================================================
    // Cmd+T = TERMINAL
    // =====================================================================

    // Cmd+T T — Toggle Terminal
    {
        "key": "cmd+t cmd+t",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    { "key": "ctrl+`",         "command": "workbench.action.terminal.toggleTerminal" },
    { "key": "ctrl+backquote", "command": "workbench.action.terminal.toggleTerminal" },

    // Cmd+T C — Terminal Create (new)
    {
        "key": "cmd+t cmd+c",
        "command": "workbench.action.terminal.new",
        "when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
    },
    {
        "key": "cmd+shift+`",
        "command": "-workbench.action.terminal.new",
        "when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
    },

    // Cmd+T D — Terminal Delete (kill)
    {
        "key": "cmd+t cmd+d",
        "command": "workbench.action.terminal.kill"
    },
    {
        "key": "delete",
        "command": "-workbench.action.terminal.killActiveTab",
        "when": "terminalHasBeenCreated && terminalTabsFocus || terminalIsOpen && terminalTabsFocus || terminalProcessSupported && terminalTabsFocus"
    },

    // Cmd+T S — Terminal Split
    {
        "key": "cmd+t cmd+s",
        "command": "workbench.action.terminal.split",
        "when": "terminalFocus && terminalProcessSupported || terminalFocus && terminalWebExtensionContributedProfile"
    },

    // Cmd+T F — Terminal Find
    {
        "key": "cmd+t cmd+f",
        "command": "workbench.action.terminal.focusFind",
        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
    },
    {
        "key": "cmd+f",
        "command": "-workbench.action.terminal.focusFind",
        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
    },

    // Cmd+T R — Terminal Resize (toggle maximized)
    {
        "key": "cmd+t cmd+r",
        "command": "workbench.action.toggleMaximizedPanel",
        "when": "terminalFocus"
    },

    // Terminal Focus Next/Previous
    {
        "key": "cmd+alt+down",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
    },
    {
        "key": "cmd+alt+up",
        "command": "workbench.action.terminal.focusPrevious",
        "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
    },

    // =====================================================================
    // FIND (editor) — moved to Cmd+Alt+F since Cmd+F is "Focus" namespace
    // =====================================================================
    {
        "key": "cmd+alt+f",
        "command": "actions.find",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "cmd+f",
        "command": "-actions.find",
        "when": "editorFocus || editorIsOpen"
    },

    // =====================================================================
    // SYMBOL NAVIGATION
    // =====================================================================

    // Ctrl+O — Go to Symbol in File
    {
        "key": "ctrl+o",
        "command": "workbench.action.gotoSymbol",
        "when": "!accessibilityHelpIsShown && !accessibleViewIsShown"
    },
    {
        "key": "cmd+shift+o",
        "command": "-workbench.action.gotoSymbol",
        "when": "!accessibilityHelpIsShown && !accessibleViewIsShown"
    },
    {
        "key": "cmd+o",
        "command": "-workbench.action.gotoSymbol",
        "when": "!accessibilityHelpIsShown && !accessibleViewIsShown"
    },

    // Ctrl+Shift+O — Go to Symbol in Workspace
    {
        "key": "ctrl+shift+o",
        "command": "workbench.action.showAllSymbols"
    },
    {
        "key": "cmd+t",
        "command": "-workbench.action.showAllSymbols"
    },
    {
        "key": "cmd+shift+o",
        "command": "-workbench.action.showAllSymbols"
    },

    // Command Palette
    {
        "key": "ctrl+shift+p",
        "command": "workbench.action.showCommands"
    },
    {
        "key": "cmd+shift+p",
        "command": "-workbench.action.showCommands"
    }
]
